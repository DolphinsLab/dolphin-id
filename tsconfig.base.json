{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@dolphin-id/core": ["packages/core/src/index.ts"],
      "@dolphin-id/react": ["packages/react/src/index.tsx"],
      "@dolphin-id/ui": ["packages/ui/src/index.tsx"],
      "@dolphin-id/adapter-evm": ["packages/adapter-evm/src/index.ts"],
      "@dolphin-id/adapter-sui": ["packages/adapter-sui/src/index.ts"],
      "@dolphin-id/server": ["packages/server/src/index.ts"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  }
}
