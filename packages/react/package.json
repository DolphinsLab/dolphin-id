{
  "name": "@dolphin-id/react",
  "version": "0.1.0",
  "description": "React provider and headless hooks for Dolphin ID.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --external react",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@dolphin-id/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
