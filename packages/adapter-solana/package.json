{
  "name": "@dolphin-id/adapter-solana",
  "version": "0.0.0",
  "description": "Solana wallet adapter package for Dolphin ID.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dolphin-id/core": "workspace:*",
    "@scure/base": "^1.2.6"
  },
  "devDependencies": {
    "@noble/curves": "^1.9.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
