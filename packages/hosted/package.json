{
  "name": "@dolphin-id/hosted",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Hosted nonce and session service primitives for Dolphin ID.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dolphin-id/server": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
